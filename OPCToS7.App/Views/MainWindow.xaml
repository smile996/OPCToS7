<Window
    x:Class="OPCToS7.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cvt="clr-namespace:OPCToS7.App.Converter"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Title="OPC UA 转 S7-1511 智能网关控制台"
    Width="1200"
    Height="760"
    Background="#F0F2F5"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <cvt:BooleanToBrushConverter x:Key="BooleanToBrushConverter" />
        <cvt:InverseBooleanConverter x:Key="InverseBooleanConverter" />

        <cvt:VisibleIfVariableConverter x:Key="VisibleIfVariableConverter" />
        <cvt:VisibleIfObjectConverter x:Key="VisibleIfObjectConverter" />
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="0,0,0,10"
            Padding="15"
            Background="White"
            CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,5,0"
                        FontWeight="Bold"
                        Text="OPC UA:" />
                    <Border
                        Width="12"
                        Height="12"
                        Margin="0,0,15,0"
                        Background="{Binding IsOpcConnected, Converter={StaticResource BooleanToBrushConverter}}"
                        CornerRadius="6" />

                    <TextBlock
                        Margin="0,0,5,0"
                        FontWeight="Bold"
                        Text="S7-1511 PLC:" />
                    <Border
                        Width="12"
                        Height="12"
                        Margin="0,0,25,0"
                        Background="{Binding IsS7Connected, Converter={StaticResource BooleanToBrushConverter}}"
                        CornerRadius="6" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Text="目标PLC IP: " />
                    <TextBox
                        Width="120"
                        Margin="0,0,15,0"
                        Text="{Binding PlcConfig.IpAddress}" />
                    <TextBlock VerticalAlignment="Center" Text="Rack: " />
                    <TextBox
                        Width="30"
                        Margin="0,0,10,0"
                        Text="{Binding PlcConfig.Rack}" />
                    <TextBlock VerticalAlignment="Center" Text="Slot: " />
                    <TextBox
                        Width="30"
                        Margin="0,0,15,0"
                        Text="{Binding PlcConfig.Slot}" />
                    <TextBlock VerticalAlignment="Center" Text="转发频率(ms): " />
                    <TextBox Width="50" Text="{Binding PlcConfig.CycleTimeMs}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button
                        Width="120"
                        Margin="0,0,10,0"
                        Background="#28A745"
                        Click="StartEngine_Click"
                        Content="▶ 启动转发引擎"
                        FontWeight="Bold"
                        Foreground="White"
                        IsEnabled="{Binding IsEngineRunning, Converter={StaticResource InverseBooleanConverter}}" />
                    <Button
                        Width="80"
                        Margin="0,0,10,0"
                        Background="#DC3545"
                        Click="StopEngine_Click"
                        Content="⏹ 停止"
                        Foreground="White"
                        IsEnabled="{Binding IsEngineRunning}" />
                    <Button
                        Width="90"
                        Click="SaveConfig_Click"
                        Content="💾 保存组态" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="10"
                Background="White"
                CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Margin="0,0,0,10"
                        FontWeight="Bold"
                        Text="1. 数据源：OPC UA 节点浏览" />
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            Margin="0,0,5,0"
                            VerticalContentAlignment="Center"
                            Text="{Binding OpcConfig.ServerUrl}" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button
                                Width="60"
                                Margin="0,0,5,0"
                                Background="#007ACC"
                                Click="BrowseOpc_Click"
                                Content="🔍扫描"
                                Foreground="White" />
                            <Button
                                Width="75"
                                Margin="0,0,5,0"
                                Background="#28A745"
                                Click="ExportCsv_Click"
                                Content="⬇️导出CSV"
                                Foreground="White"
                                ToolTip="将左侧树形变量全部导出为CSV模板" />
                            <Button
                                Width="75"
                                Background="#17A2B8"
                                Click="ImportCsv_Click"
                                Content="⬆️导入CSV"
                                Foreground="White"
                                ToolTip="读取CSV并自动生成S7映射表" />
                        </StackPanel>
                    </Grid>

                    <TreeView
                        x:Name="OpcTreeView"
                        Grid.Row="2"
                        BorderBrush="#DDD"
                        ItemsSource="{Binding OpcServerTree}"
                        SelectedItemChanged="OpcTreeView_SelectedItemChanged">

                        <TreeView.ItemContainerStyle>
                            <Style TargetType="{x:Type TreeViewItem}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                            </Style>
                        </TreeView.ItemContainerStyle>

                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Margin="0,3" Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,5,0"
                                        Foreground="#007ACC"
                                        Text="🏷️"
                                        Visibility="{Binding NodeClass, Converter={StaticResource VisibleIfVariableConverter}}" />
                                    <TextBlock
                                        Margin="0,0,5,0"
                                        Foreground="#E1B32A"
                                        Text="📁"
                                        Visibility="{Binding NodeClass, Converter={StaticResource VisibleIfObjectConverter}}" />
                                    <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                    <TextBlock
                                        Margin="10,2,0,0"
                                        VerticalAlignment="Bottom"
                                        FontSize="10"
                                        Foreground="Gray"
                                        Text="{Binding NodeId}" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Button
                    Width="50"
                    Height="40"
                    Margin="0,0,0,15"
                    Background="#007ACC"
                    Click="AddNode_Click"
                    Content="▶ 添加"
                    FontWeight="Bold"
                    Foreground="White"
                    ToolTip="将选中的变量添加到右侧映射表" />
                <Button
                    Width="50"
                    Height="40"
                    Background="#F8D7DA"
                    Click="RemoveNode_Click"
                    Content="🗑 删除"
                    Foreground="#721C24"
                    ToolTip="移除右侧选中的映射" />
            </StackPanel>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Margin="0,0,0,10"
                    Padding="10"
                    Background="White"
                    CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Margin="0,0,0,10"
                            FontWeight="Bold"
                            Text="2. 目标：西门子 DB 块偏移量路由映射表 (自动计算连续地址)" />

                        <DataGrid
                            x:Name="MapDataGrid"
                            Grid.Row="1"
                            AutoGenerateColumns="False"
                            Background="White"
                            CanUserAddRows="False"
                            ItemsSource="{Binding TagMappings}"
                            RowHeaderWidth="25"
                            SelectionMode="Extended"
                            SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn
                                    Width="40"
                                    Binding="{Binding IsActive}"
                                    Header="激活" />
                                <DataGridTextColumn
                                    Width="140"
                                    Binding="{Binding TagName}"
                                    Header="变量名称" />
                                <DataGridTextColumn
                                    Width="2*"
                                    Binding="{Binding OpcNodeId}"
                                    Header="OPC 节点 (NodeId)" />

                                <DataGridTextColumn
                                    Width="100"
                                    Binding="{Binding LinkStatus}"
                                    Header="通讯状态">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="变量错误">
                                                    <Setter Property="Foreground" Value="Red" />
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                </Trigger>
                                                <Trigger Property="Text" Value="正常">
                                                    <Setter Property="Foreground" Value="Green" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn
                                    Width="80"
                                    Binding="{Binding CurrentValue}"
                                    FontWeight="Bold"
                                    Foreground="#007ACC"
                                    Header="实时数据"
                                    IsReadOnly="True" />

                                <DataGridComboBoxColumn
                                    Width="80"
                                    Header="数据类型"
                                    SelectedValueBinding="{Binding DataType}">
                                    <DataGridComboBoxColumn.ItemsSource>
                                        <x:Array Type="{x:Type sys:String}">
                                            <sys:String>REAL</sys:String>
                                            <sys:String>DINT</sys:String>
                                            <sys:String>INT</sys:String>
                                            <sys:String>WORD</sys:String>
                                            <sys:String>BOOL</sys:String>
                                            <sys:String>STRING</sys:String>
                                        </x:Array>
                                    </DataGridComboBoxColumn.ItemsSource>
                                </DataGridComboBoxColumn>

                                <DataGridTextColumn
                                    Width="50"
                                    Binding="{Binding DbNumber}"
                                    Header="DB块" />
                                <DataGridTextColumn
                                    Width="50"
                                    Binding="{Binding ByteOffset}"
                                    Header="Byte" />
                                <DataGridTextColumn
                                    Width="40"
                                    Binding="{Binding BitOffset}"
                                    Header="Bit" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border
                    Grid.Row="1"
                    Padding="10"
                    Background="#1E1E1E"
                    CornerRadius="6">
                    <TextBox
                        Background="Transparent"
                        BorderThickness="0"
                        FontFamily="Consolas"
                        FontSize="12"
                        Foreground="#A9B7C6"
                        IsReadOnly="True"
                        Text="{Binding LogText, Mode=OneWay}"
                        TextChanged="LogTextBox_TextChanged"
                        VerticalScrollBarVisibility="Auto" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>