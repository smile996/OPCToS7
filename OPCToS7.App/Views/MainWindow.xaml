<Window
    x:Class="OPCToS7.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cvt="clr-namespace:OPCToS7.App.Converter"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Title="OPC UA 转 S7 智能网关控制台"
    Width="1400"
    Height="800"
    Background="{DynamicResource SecondaryRegionBrush}"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <cvt:BooleanToBrushConverter x:Key="BooleanToBrushConverter" />
        <cvt:InverseBooleanConverter x:Key="InverseBooleanConverter" />

        <cvt:VisibleIfVariableConverter x:Key="VisibleIfVariableConverter" />
        <cvt:VisibleIfObjectConverter x:Key="VisibleIfObjectConverter" />

        <cvt:StatusColorConverter x:Key="StatusColorConverter" />
        
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <hc:Card Grid.Row="0" Margin="0,0,0,15" Padding="15,10" Background="{DynamicResource RegionBrush}" BorderThickness="0" Effect="{DynamicResource EffectShadow2}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <Border Width="12" Height="12" Margin="0,0,8,0" CornerRadius="6" Background="{Binding IsOpcConnected, Converter={StaticResource BooleanToBrushConverter}}">
                        <Border.Effect>
                            <DropShadowEffect Color="LimeGreen" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                        </Border.Effect>
                    </Border>
                    <TextBlock Text="OPC UA" FontWeight="Bold" FontSize="14" Margin="0,0,20,0" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>

                    <Border Width="12" Height="12" Margin="0,0,8,0" CornerRadius="6" Background="{Binding IsS7Connected, Converter={StaticResource BooleanToBrushConverter}}">
                        <Border.Effect>
                            <DropShadowEffect Color="LimeGreen" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                        </Border.Effect>
                    </Border>
                    <TextBlock Text="S7-1511" FontWeight="Bold" FontSize="14" Margin="0,0,20,0" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Text="PLC IP:" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,5,0"/>
                    <TextBox Width="120" Margin="0,0,15,0" hc:InfoElement.Placeholder="192.168.0.1" Text="{Binding PlcConfig.IpAddress}" />

                    <TextBlock VerticalAlignment="Center" Text="Rack:" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,5,0"/>
                    <TextBox Width="40" Margin="0,0,15,0" Text="{Binding PlcConfig.Rack}" />

                    <TextBlock VerticalAlignment="Center" Text="Slot:" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,5,0"/>
                    <TextBox Width="40" Margin="0,0,15,0" Text="{Binding PlcConfig.Slot}" />

                    <TextBlock VerticalAlignment="Center" Text="微拍节(ms):" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,5,0"/>
                    <TextBox Width="60" Text="{Binding PlcConfig.CycleTimeMs}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Width="130" Margin="0,0,10,0" hc:BorderElement.CornerRadius="4" Background="#28A745" Foreground="White" FontWeight="Bold" Content="▶ 启动双擎" Click="StartEngine_Click" IsEnabled="{Binding IsEngineRunning, Converter={StaticResource InverseBooleanConverter}}" />
                    <Button Width="90" Margin="0,0,10,0" hc:BorderElement.CornerRadius="4" Background="#DC3545" Foreground="White" Content="⏹ 停止" Click="StopEngine_Click" IsEnabled="{Binding IsEngineRunning}" />
                    <Button Width="100" hc:BorderElement.CornerRadius="4" Style="{StaticResource ButtonPrimary}" Content="💾 固化组态" Click="SaveConfig_Click" />
                </StackPanel>
            </Grid>
        </hc:Card>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <hc:Card Grid.Column="0" Padding="10" Background="{DynamicResource RegionBrush}" BorderThickness="0" Effect="{DynamicResource EffectShadow1}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Margin="0,0,0,10" FontWeight="Black" FontSize="14" Foreground="{DynamicResource PrimaryBrush}" Text="▍ 第一步: OPC UA 节点探针" />

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Margin="0,0,5,0" VerticalContentAlignment="Center" Text="{Binding OpcConfig.ServerUrl}" hc:InfoElement.Placeholder="opc.tcp://..." />

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Width="60" Margin="0,0,5,0" Style="{StaticResource ButtonPrimary}" Content="🔍扫描" Click="BrowseOpc_Click" />
                            <Button Width="35" Margin="0,0,5,0" Background="#28A745" Foreground="White" Content="⬇️" ToolTip="导出当前树形CSV组态模板" Click="ExportCsv_Click" />
                            <Button Width="35" Background="#17A2B8" Foreground="White" Content="⬆️" ToolTip="直接导入CSV物理地址映射表" Click="ImportCsv_Click" />
                        </StackPanel>
                    </Grid>

                    <TreeView x:Name="OpcTreeView" Grid.Row="2" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" ItemsSource="{Binding OpcServerTree}" SelectedItemChanged="OpcTreeView_SelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="{x:Type TreeViewItem}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Margin="0,4" Orientation="Horizontal">
                                    <TextBlock Margin="0,0,6,0" Foreground="#2196F3" Text="●" Visibility="{Binding NodeClass, Converter={StaticResource VisibleIfVariableConverter}}" />
                                    <TextBlock Margin="0,0,6,0" Foreground="#FFC107" Text="📁" Visibility="{Binding NodeClass, Converter={StaticResource VisibleIfObjectConverter}}" />
                                    <TextBlock FontWeight="SemiBold" FontSize="13" Text="{Binding DisplayName}" />
                                    <TextBlock Margin="8,1,0,0" VerticalAlignment="Bottom" FontSize="11" Foreground="{DynamicResource ThirdTextBrush}" Text="{Binding NodeId}" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </hc:Card>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Width="40" Height="40" Margin="0,0,0,20" hc:BorderElement.CornerRadius="20" Style="{StaticResource ButtonPrimary}" Content="▶" FontSize="18" ToolTip="挂载选定节点" Click="AddNode_Click" />
                <Button Width="40" Height="40" hc:BorderElement.CornerRadius="20" Style="{StaticResource ButtonDanger}" Content="🗑" FontSize="16" ToolTip="剥离映射节点" Click="RemoveNode_Click" />
            </StackPanel>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>

                <hc:Card Grid.Row="0" Margin="0,0,0,15" Padding="10" Background="{DynamicResource RegionBrush}" BorderThickness="0" Effect="{DynamicResource EffectShadow1}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Margin="0,0,0,10" FontWeight="Black" FontSize="14" Foreground="{DynamicResource PrimaryBrush}" Text="▍ 第二步: S7 物理内存路由与双向状态监控表" />

                        <DataGrid x:Name="MapDataGrid" Grid.Row="1" 
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False"
                                  RowHeaderWidth="40"
                                  hc:DataGridAttach.ShowRowNumber="True"
                                  AlternatingRowBackground="{DynamicResource SecondaryRegionBrush}"
                                  ItemsSource="{Binding TagMappings}" 
                                  SelectionMode="Extended" 
                                  SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="使能" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ToggleButton Style="{StaticResource ToggleButtonSwitch}" IsChecked="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="工业变量名" Binding="{Binding TagName}" Width="*" FontWeight="Bold"/>
                                <DataGridTextColumn Header="OPC 寻址 (NodeId)" Binding="{Binding OpcNodeId}" Width="2*" IsReadOnly="True" Foreground="{DynamicResource ThirdTextBrush}"/>

                                <DataGridTextColumn Header="同步状态" Binding="{Binding LinkStatus}" Width="*" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding LinkStatus, Converter={StaticResource StatusColorConverter}}" />
                                            <Setter Property="FontWeight" Value="Heavy" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="实时数据" Binding="{Binding CurrentValue}" Width="*" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Consolas" />
                                            <Setter Property="FontSize" Value="15" />
                                            <Setter Property="FontWeight" Value="Bold" />
                                            <Setter Property="Foreground" Value="#00C853" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridComboBoxColumn Header="强类型" Width="*" SelectedValueBinding="{Binding DataType}">
                                    <DataGridComboBoxColumn.ItemsSource>
                                        <x:Array Type="{x:Type sys:String}">
                                            <sys:String>REAL</sys:String>
                                            <sys:String>DINT</sys:String>
                                            <sys:String>INT</sys:String>
                                            <sys:String>WORD</sys:String>
                                            <sys:String>BOOL</sys:String>
                                            <sys:String>STRING</sys:String>
                                        </x:Array>
                                    </DataGridComboBoxColumn.ItemsSource>
                                </DataGridComboBoxColumn>

                                <DataGridTextColumn Header="DB块" Binding="{Binding DbNumber}" Width="*" Foreground="#007ACC" FontWeight="Bold"/>
                                <DataGridTextColumn Header="Byte" Binding="{Binding ByteOffset}" Width="*" Foreground="#E65100"/>
                                <DataGridTextColumn Header="Bit" Binding="{Binding BitOffset}" Width="*" Foreground="#607D8B"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </hc:Card>

                <hc:Card Grid.Row="1" Padding="10" Background="#0D1117" BorderThickness="0" hc:BorderElement.CornerRadius="6">
                    <Grid>
                        <TextBlock Text="Terminal Log" Foreground="#444" FontSize="20" FontWeight="Black" Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Top" Panel.ZIndex="0"/>
                        <TextBox Background="Transparent" BorderThickness="0" FontFamily="Consolas" FontSize="13" Foreground="#10B981" IsReadOnly="True" Text="{Binding LogText, Mode=OneWay}" TextChanged="LogTextBox_TextChanged" VerticalScrollBarVisibility="Auto" Panel.ZIndex="1"/>
                    </Grid>
                </hc:Card>
            </Grid>
        </Grid>
    </Grid>
</Window>